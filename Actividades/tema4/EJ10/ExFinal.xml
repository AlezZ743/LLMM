  <seccion id="7" titulo="The XML Standard">
    <theory_answers>
      <question id="a">
        <text>What do comments look like?</text>
        <answer>They look like &lt;!-- comment --&gt;</answer>
      </question>
      <question id="b">
        <text>Can an attribute be repeated?</text>
        <answer>No, section 3.1 states it must not appear more than once.</answer>
      </question>
      <question id="c">
        <text>Tag matching rule location?</text>
        <answer>Stated in Section 3.1: Start-tags and End-tags must match.</answer>
      </question>
    </theory_answers>
